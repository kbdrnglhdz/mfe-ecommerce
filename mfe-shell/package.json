    "single-spa": "^5.9.3",
    "single-spa-layout": "^2.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.0",
    "@babel/preset-react": "^7.16.0",
    "babel-loader": "^8.2.3",
    "css-loader": "^6.5.1",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.1",
    "systemjs-webpack-interop": "^2.3.7",
    "webpack": "^5.62.2",
    "webpack-cli": "^4.9.1",
    "webpack-config-single-spa": "^8.0.0",
    "webpack-dev-server": "^4.4.0",
    "webpack-merge": "^5.8.0"
